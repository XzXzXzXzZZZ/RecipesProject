 <Window x:Class="RecipesProject.UI.MainMenu.WindowMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RecipesProject.UI.MainMenu"
        mc:Ignorable="d"
        Title="Рецепты" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        MinHeight="400" MinWidth="600">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с поиском -->
        <Border x:Name="SearchBorder" Grid.Row="0" Background="LightGray" Margin="10,10,10,0" CornerRadius="5" Visibility="Visible">
            <Grid>
                <TextBox x:Name="SearchTextBox" 
                         Height="35" 
                         Width="500"
                         FontSize="18" 
                         Text="Поиск..."
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         Margin="10"
                         Padding="5"/>
            </Grid>
        </Border>

        <!-- Контентная область, которая будет меняться -->
        <ContentControl x:Name="MainContentControl" Grid.Row="1" Margin="10"/>

        <!-- Динамическая панель с кнопками -->
        <Border Grid.Row="2" Background="Transparent" Margin="10">
            <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>