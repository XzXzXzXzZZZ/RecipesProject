<UserControl x:Class="RecipesProject.UI.NewRecepts.NewReceptControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--скролл -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Background="White" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Добавление нового рецепта" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Название блюда:" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="NameTextBox" Height="35" Padding="5" FontSize="14"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="Ингредиенты:" 
                               FontSize="14" 
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <!--Текстбокс для поиска -->
                    <TextBox x:Name="SearchIngredientTextBox" 
                             Grid.Column="1"
                             Width="200"
                             Height="30"
                             Padding="5" 
                             FontSize="12"
                             Text="Какой ингредиент вы ищете?"
                             Foreground="Gray"
                             VerticalAlignment="Center"
                             GotFocus="SearchIngredientTextBox_GotFocus"
                             LostFocus="SearchIngredientTextBox_LostFocus"/>
                </Grid>

                <!--текстбокс для ингредиентов -->
                <TextBox x:Name="IngredientsTextBox" 
                         Height="150" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         Padding="5" 
                         FontSize="14"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>

            <Button x:Name="GoToStepsButton"
                    Grid.Row="3"
                    Content="➡ Перейти к созданию шагов" 
                    Height="45" 
                    Width="200"
                    FontSize="14"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,20"
                    Background="LightBlue"
                    Cursor="Hand"
                    Click="GoToStepsButton_Click"/>

            <Rectangle Grid.Row="4" Height="20"/>
        </Grid>
    </ScrollViewer>
</UserControl>