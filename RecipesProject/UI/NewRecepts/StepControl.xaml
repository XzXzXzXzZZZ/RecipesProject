<UserControl x:Class="RecipesProject.UI.NewRecepts.StepControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Background="White" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0"
                       Text="Создание шагов приготовления" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <!-- Информация о рецепте -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Рецепт:" FontSize="18" Margin="0,0,0,5"/>
                <TextBlock x:Name="RecipeNameText" 
                           Text="[Название рецепта]" 
                           FontSize="16" 
                           FontWeight="SemiBold"
                           Foreground="DarkBlue"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Шаги приготовления:" FontSize="18" Margin="0,0,0,5"/>

                <!-- Поле для ввода шага с подсказкой внутри -->
                <Grid Margin="0,0,0,10" Width="400" HorizontalAlignment="Left">
                    <TextBox x:Name="StepTextBox" 
                             Height="35" 
                             Padding="5" 
                             FontSize="14"
                             GotFocus="StepTextBox_GotFocus"
                             LostFocus="StepTextBox_LostFocus"
                             TextChanged="StepTextBox_TextChanged"/>
                    <TextBlock x:Name="PlaceholderText"
                               Text="Введите шаг приготовления..."
                               Height="35"
                               Padding="5"
                               FontSize="14"
                               Foreground="Gray"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                </Grid>

                <Button x:Name="AddStepButton"
                        Content="➕ Добавить шаг" 
                        Height="35" 
                        Width="120"
                        Margin="0,5,0,10"
                        HorizontalAlignment="Left"
                        Background="LightGreen"
                        Cursor="Hand"
                        Click="AddStepButton_Click"/>

                <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="StepsListBox" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </StackPanel>

            <!-- Время приготовления -->
            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                <TextBlock Text="Время приготовления:" FontSize="18" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <!-- Часы (опционально) -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                        <TextBox x:Name="HoursTextBox" 
                                 Width="60" 
                                 Height="35" 
                                 Padding="5" 
                                 FontSize="14"
                                 TextAlignment="Center"
                                 MaxLength="3"
                                 PreviewTextInput="HoursTextBox_PreviewTextInput"
                                 TextChanged="HoursTextBox_TextChanged"
                                 GotFocus="HoursTextBox_GotFocus"
                                 LostFocus="HoursTextBox_LostFocus"/>
                        <TextBlock Text="ч" 
                                   FontSize="14" 
                                   VerticalAlignment="Center" 
                                   Margin="5,0,0,0"/>
                        <TextBlock x:Name="HoursPlaceholderText"
                                   Text="0"
                                   FontSize="14"
                                   Foreground="Gray"
                                   VerticalAlignment="Center"
                                   Margin="-55,0,0,0"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Минуты (опционально) -->
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="MinutesTextBox" 
                                 Width="60" 
                                 Height="35" 
                                 Padding="5" 
                                 FontSize="14"
                                 TextAlignment="Center"
                                 MaxLength="2"
                                 PreviewTextInput="MinutesTextBox_PreviewTextInput"
                                 TextChanged="MinutesTextBox_TextChanged"
                                 GotFocus="MinutesTextBox_GotFocus"
                                 LostFocus="MinutesTextBox_LostFocus"/>
                        <TextBlock Text="м" 
                                   FontSize="14" 
                                   VerticalAlignment="Center" 
                                   Margin="5,0,0,0"/>
                        <TextBlock x:Name="MinutesPlaceholderText"
                                   Text="0"
                                   FontSize="14"
                                   Foreground="Gray"
                                   VerticalAlignment="Center"
                                   Margin="-55,0,0,0"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                <Button x:Name="BackButton"
                        Content="◀ Назад к ингредиентам" 
                        Height="40" 
                        Width="180"
                        FontSize="14"
                        Margin="5"
                        Background="IndianRed"
                        Cursor="Hand"
                        Click="BackButton_Click"/>

                <Button x:Name="SaveRecipeButton"
                        Content="💾 Сохранить рецепт" 
                        Height="40" 
                        Width="180"
                        FontSize="14"
                        Margin="5"
                        Background="LightGreen"
                        Cursor="Hand"
                        Click="SaveRecipeButton_Click"/>
            </StackPanel>

            <Rectangle Grid.Row="5" Height="20"/>
        </Grid>
    </ScrollViewer>
</UserControl>