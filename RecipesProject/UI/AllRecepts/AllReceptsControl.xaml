<UserControl x:Class="RecipesProject.UI.AllRecepts.AllReceptsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

	<Grid Background="White">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0"
                   Text="Все рецепты"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="10,10,10,5"
                   Foreground="#333"/>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<ListBox x:Name="ReceptsListBox"
                     BorderThickness="0"
                     Margin="5"
                     MouseDoubleClick="ReceptsListBox_MouseDoubleClick">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<Border Background="White"
                                CornerRadius="8"
                                Padding="15"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Margin="0,0,0,5"
                                Cursor="Hand">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="50"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<!-- Иконка -->
								<Border Grid.Column="0"
                                        Width="45"
                                        Height="45"
                                        Background="IndianRed"
                                        CornerRadius="22"
                                        VerticalAlignment="Center">
									<TextBlock Text="🍽️"
                                              FontSize="22"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
								</Border>

								<!-- Информация -->
								<StackPanel Grid.Column="1" Margin="12,0">
									<TextBlock Text="{Binding Title}"
                                              FontSize="15"
                                              FontWeight="SemiBold"
                                              Foreground="#333"/>
									<TextBlock Text="{Binding Description}"
                                              FontSize="12"
                                              Foreground="#888"
                                              TextTrimming="CharacterEllipsis"
                                              MaxHeight="36"
                                              Margin="0,2,0,0"/>
									<StackPanel Orientation="Horizontal" Margin="0,4,0,0">
										<TextBlock Text="⏱️" FontSize="11" Margin="0,0,3,0"/>
										<TextBlock Text="{Binding CookingTime, StringFormat={}{0} мин}"
                                                  FontSize="11"
                                                  Foreground="#666"
                                                  Margin="0,0,10,0"/>
										<TextBlock Text="👥" FontSize="11" Margin="0,0,3,0"/>
										<TextBlock Text="{Binding Servings, StringFormat={}{0} порц.}"
                                                  FontSize="11"
                                                  Foreground="#666"/>
									</StackPanel>
								</StackPanel>

								<!-- Избранное -->
								<TextBlock Grid.Column="2"
                                          Text="⭐"
                                          FontSize="18"
                                          Foreground="#FFD700"
                                          VerticalAlignment="Center"/>
							</Grid>
						</Border>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>
		</ScrollViewer>
	</Grid>
</UserControl>