<UserControl x:Class="RecipesProject.UI.NewRecepts.NewReceptControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White">
        <StackPanel Margin="20">
            <TextBlock Text="Добавление нового рецепта" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Название блюда:" FontSize="14" Margin="0,5"/>
            <TextBox Height="35" Margin="0,0,0,15" Padding="5"/>

            <TextBlock Text="Ингредиенты:" FontSize="14" Margin="0,5"/>
            <TextBox Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" Padding="5"/>

            <TextBlock Text="Инструкция приготовления:" FontSize="14" Margin="0,5"/>
            <TextBox Height="120" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20" Padding="5"/>

            <Button Content="💾 Сохранить рецепт" 
                    Height="45" 
                    Width="180"
                    FontSize="14"
                    HorizontalAlignment="Center"
                    Background="LightGreen"/>
        </StackPanel>
    </Grid>
</UserControl>