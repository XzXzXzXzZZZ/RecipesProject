<UserControl x:Class="RecipesProject.UI.NewRecepts.StepControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Добавляем ScrollViewer для всего содержимого -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Background="White" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0"
                       Text="Создание шагов приготовления" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <!-- Информация о рецепте -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Рецепт:" FontSize="14" Margin="0,0,0,5"/>
                <TextBlock x:Name="RecipeNameText" 
                           Text="[Название рецепта]" 
                           FontSize="16" 
                           FontWeight="SemiBold"
                           Foreground="DarkBlue"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Шаги приготовления:" FontSize="14" Margin="0,0,0,5"/>
                
                <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <ListBox x:Name="StepsListBox" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBox x:Name="StepTextBox" 
                             Width="300" 
                             Height="35" 
                             Padding="5" 
                             FontSize="14"
                             Text="Введите шаг..."/>
                    <Button x:Name="AddStepButton"
                            Content="➕ Добавить шаг" 
                            Height="35" 
                            Width="120"
                            Margin="10,0,0,0"
                            Background="LightGreen"
                            Cursor="Hand"
                            Click="AddStepButton_Click"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                <Button x:Name="BackButton"
                        Content="◀ Назад к ингредиентам" 
                        Height="40" 
                        Width="180"
                        FontSize="14"
                        Margin="5"
                        Background="IndianRed"
                        Cursor="Hand"
                        Click="BackButton_Click"/>

                <Button x:Name="SaveRecipeButton"
                        Content="💾 Сохранить рецепт" 
                        Height="40" 
                        Width="180"
                        FontSize="14"
                        Margin="5"
                        Background="LightGreen"
                        Cursor="Hand"
                        Click="SaveRecipeButton_Click"/>
            </StackPanel>

            <Rectangle Grid.Row="4" Height="20"/>
        </Grid>
    </ScrollViewer>
</UserControl>