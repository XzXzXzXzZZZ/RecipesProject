<UserControl x:Class="RecipesProject.UI.FavRecepts.FavReceptsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Grid Background="White">
		<ScrollViewer>
			<StackPanel Margin="10">
				<TextBlock Text="Любимые рецепты"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>
				<ListBox x:Name="FavReceptsListBox"
                         Height="300"
                         MouseDoubleClick="FavReceptsListBox_MouseDoubleClick"/>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>